# IPCAS customer / demo deployment (Docker full stack)
# Copied to .env automatically by customer/install scripts on first run.

COMPOSE_PROJECT_NAME=ipcas

# Web build (Docker)
VITE_API_BASE_URL=http://localhost:8080/api

# API (Django)
SECRET_KEY=customer-demo-change-me
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,api,traefik
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://localhost:8080
FRONTEND_URL=http://localhost:8080

# PostgreSQL (internal Docker network — do not change hostnames)
DATABASE_URL=postgres://ipcas:ipcas@postgres:5432/ipcas
POSTGRES_USER=ipcas
POSTGRES_PASSWORD=ipcas
POSTGRES_DB=ipcas

TRAEFIK_HTTP_PORT=8080

# RabbitMQ
RABBITMQ_URL=amqp://ipcas:ipcas@rabbitmq:5672/
RABBITMQ_DEFAULT_USER=ipcas
RABBITMQ_DEFAULT_PASS=ipcas
AUDIT_LOG_ASYNC=true

# MinIO / S3
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=ipcas
AWS_SECRET_ACCESS_KEY=ipcas-secret
AWS_STORAGE_BUCKET_NAME=ipcas-files
AWS_S3_REGION_NAME=us-east-1
AWS_S3_USE_SSL=false
