# Web (Vite — build-time)
VITE_API_BASE_URL=http://localhost:8000/api

# API (Django)
SECRET_KEY=change-me-in-production
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,api,traefik
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://localhost:8080
FRONTEND_URL=http://localhost:5173

# PostgreSQL (required) — host port 5433 avoids conflict with a system Postgres on 5432
DATABASE_URL=postgres://ipcas:ipcas@localhost:5433/ipcas
POSTGRES_USER=ipcas
POSTGRES_PASSWORD=ipcas
POSTGRES_DB=ipcas

# Traefik gateway (docker-compose)
TRAEFIK_HTTP_PORT=8080

# RabbitMQ
RABBITMQ_URL=amqp://ipcas:ipcas@localhost:5672/
RABBITMQ_DEFAULT_USER=ipcas
RABBITMQ_DEFAULT_PASS=ipcas
AUDIT_LOG_ASYNC=true

# Celery (MSP import and async tasks)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# Set true for local dev without Redis/Celery worker
CELERY_TASK_ALWAYS_EAGER=false

# MinIO / S3
AWS_S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=ipcas
AWS_SECRET_ACCESS_KEY=ipcas-secret
AWS_STORAGE_BUCKET_NAME=ipcas-files
AWS_S3_REGION_NAME=us-east-1
AWS_S3_USE_SSL=false
